# llama.cpp llama-server (7B) — フレーム多枚画像方式
# 起動例: llama-server --model <path>/Qwen2.5-VL-7B-Instruct-Q4_K_M.gguf --mmproj <path>/mmproj-Qwen2.5-VL-7B-Instruct-f16.gguf --port 8082
LLAMA_SERVER_URL=http://127.0.0.1:8082/v1
LLAMA_MODEL_ID=qwen2.5-vl-7b

# llama.cpp llama-server (72B) — フレーム多枚画像方式 (高品質)
# 起動例: llama-server --model <path>/Qwen2.5-VL-72B-Instruct-Q4_K_M.gguf --mmproj <path>/mmproj-Qwen2.5-VL-72B-Instruct-f16.gguf --port 8083
LLAMA_72B_SERVER_URL=http://127.0.0.1:8083/v1
LLAMA_72B_MODEL_ID=qwen2.5-vl-72b

# mlx-vlm FastAPI サービス — ネイティブ動画入力 (M-RoPE)
# 起動方法: services/mlx-vlm-server/README.md を参照
MLX_VLM_BASE_URL=http://127.0.0.1:8001
